// CRE Copilot — Phase 1 table schemas
// Run once against the CopilotDb database (the generator script does this for you,
// but you can also paste these into the ADX web UI query pane).

// Raw time-series metrics for every service (latency_ms, error_rate, cpu_pct, req_per_sec).
.create-merge table Telemetry (
    Timestamp:   datetime,
    Service:     string,
    Metric:      string,
    Value:       real,
    Environment: string
)

// Deployment events — the key correlation signal. Most are innocent; one is the culprit.
.create-merge table Deployments (
    Timestamp:   datetime,
    Service:     string,
    Version:     string,
    CommitId:    string,
    Author:      string,
    Pipeline:    string,
    Environment: string
)

// Fired alerts (threshold breaches). The Detector also writes here.
.create-merge table Alerts (
    Timestamp:     datetime,
    AlertId:       string,
    Service:       string,
    Metric:        string,
    Severity:      string,
    Threshold:     real,
    ObservedValue: real,
    Description:   string
)

// Incident records — history for MTTR/dashboards + rows the orchestrator writes at runtime.
.create-merge table Incidents (
    IncidentId:   string,
    StartTime:    datetime,
    EndTime:      datetime,
    Service:      string,
    Severity:     string,
    RootCause:    string,
    Status:       string,
    ResolvedBy:   string,   // "auto" (agent) or a human handle — the confidence-gate outcome
    Confidence:   real
)

// Service topology: "Service DependsOn <upstream>". Lets the Correlator reason about cascades.
.create-merge table ServiceDependencies (
    Service:   string,
    DependsOn: string
)

// Runbook store — the growing playbook. Keyed by failure Signature (service + failure mode).
// The Runbook agent (during triage) MATCHES against this; the Postmortem agent (after
// resolution) AUTHORS new entries here when an incident was novel.
.create-merge table Runbooks (
    RunbookId:   string,
    Signature:   string,
    Service:     string,
    FailureType: string,
    Steps:       string,
    CreatedBy:   string,
    CreatedAt:   datetime,
    TimesUsed:   long
)

// Real logs scraped from the microservices by the collector (evidence for the agents).
.create-merge table Logs (
    Timestamp: datetime,
    Service:   string,
    Level:     string,
    Message:   string
)

// Post-incident reviews written by the Postmortem agent after an incident resolves.
.create-merge table Postmortems (
    PostmortemId: string,
    Service:      string,
    RootCause:    string,
    Review:       string,
    Novel:        bool,
    CreatedAt:    datetime
)
